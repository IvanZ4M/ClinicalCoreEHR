# ClinicalCore EHR — variables de entorno
# Copiar este archivo como .env y ajustar los valores para cada despliegue.
# NUNCA commitear el archivo .env real (está en .gitignore).

# URL del servidor PocketBase en la red local de la clínica
# Ejemplo: http://192.168.1.100:8090
VITE_POCKETBASE_URL=http://[IP-SERVIDOR]:8090

# Tiempo de inactividad en ms antes de cerrar sesión (default: 1800000 = 30 min)
# VITE_INACTIVITY_TIMEOUT=1800000
